rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /submissions/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.resource == null || request.resource.size < 50 * 1024 * 1024);
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
